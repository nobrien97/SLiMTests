// Setup population
1 early() {
	catn("Loading population...");
	LoadPopulation();
		
	// Remove p2
	if (exists("p2")) {
		p2.removeSubpopulation();
	}
		sim.addSubpop("p3", 0);
		
   // Sample N_replicates genotypes to calculate mutations from
	community.rescheduleScriptBlock(s1, start = sim.cycle + 1, end = sim.cycle + N_replicates * 2);
	defineGlobal("cur_index", 0);
	// Diagnostics for this run
	catn(paste0("Running modelindex: ", modelindex, "; seed: ", asString(seed)));

}

// handle cloning the population
s1 late() {
	catn("Running s1");
	if (cur_index % 2 != 0) {
		catn("Writing output...");
		// Measure variance
		calcPhenotype(p3.individuals, modelType);
		trait1 = p3.individuals.getTraitValues(0);
		trait2 = p3.individuals.getTraitValues(1);
		trait3 = p3.individuals.getTraitValues(2);
		trait4 = p3.individuals.getTraitValues(3);

		// Scale traits

		trait_var = float(4);
		// Find variance
		for (i in seqLen(length(trait_var))) {
			trait_var[i] = executeLambda(paste0("var(trait",i+1,");"));
		}

		trait_cov = float(6);
		combinations = matrix(c(1,2,
							  	1,3,
							 	1,4,
							  	2,3,
							  	2,4,
							  	3,4),
								nrow = 6, byrow = T);

		// Find covariance
		for (i in seqLen(length(trait_cov))) {
			trait_cov[i] = executeLambda(paste0("cov(trait",combinations[i,0],", trait",combinations[i,1],");"));
		}

		// Covariance of phenotypes with each molecular component
		molComps = p3.individuals.ODEPars;
		
		// molVals: Each row is an individual, columns are mol comps
		molVals = matrix(molComps, nrow = length(p3.individuals), byrow = T);

		// molTraitCovs: Rows are traits, columns are comps (so value in index 0, 0 is cov(trait1, comp1))
		molTraitCovs = matrix(float(ncol(molVals) * length(trait_var)), nrow = length(trait_var));
		for (i in seqLen(length(trait_var))) {
			for (j in seqLen(ncol(molVals))) {
				molTraitCovs[i, j] = executeLambda(paste0("cov(trait",i+1,", c(molVals[,",j,"]));"));
			}
		}

		// Write output
		WriteMutVarOutput(trait_var, trait_cov);
		WriteMutVarPerMolComp(molTraitCovs);
	} 

	defineGlobal("cur_index", cur_index + 1);

	// Move output
	if (cur_index == N_replicates * 2) {
		system(paste0("mv ./", outMutVar, " ", moveDir));
		system(paste0("mv ./", outMutVarPerComp, " ", moveDir));
	}
}


// full-sib half-sib mating design: we want to keep variability around though,
// so we still sample the rest of the population according to the regular rules
reproduction(p1) {	
	// Allow mutations to accrue every other generation
	if (cur_index % 2 != 0) {
		self.active = 0;
		return;
	} 
	
	// Create a new sample from p1
	if (cur_index % 2 == 0) {
		// Clone p2 from ind	
		ind = p1.sampleIndividuals(1);
		p3.addCloned(ind, N_p2);
		self.active = 0;
	}
}

reproduction(p3) {
	if (cur_index % 2 != 0) {
		// Clone p3 from ind	
		p3.addCloned(individual, 1);
		return;
	}
	
	self.active = 0;
	return;
}

survival(p1) {
	return T;
}

survival(p3) {
	return (individual.age < 1);
}

function (void) WriteMutVarOutput(f variance, f covariance) {
	Mfile = paste(cur_index, asString(seed), modelindex, variance, covariance, sep=",");
	writeFile(outMutVar, Mfile, append = T);
}

function (void) WriteMutVarPerMolComp(f covMatrix) {
	// Print out matrix by row
	// So order is cov(trait1, comp1), cov(trait1, comp 2), ... cov(traitn, compn)
	Mfile = paste(cur_index, asString(seed), modelindex, t(covMatrix), sep=",");
	writeFile(outMutVarPerComp, Mfile, append = T);
}


function (void) LoadPopulation(void) {
	sim.readFromPopulationFile(paste0(inputPath, "slim_popstate", inputID, ".bin"));
	
	// QTL positions
	// TODO: Remove inputPath - used for testing
	pos = readCSV(paste0(inputPath, "slim_pos", inputID, ".csv"), colNames = F);
	defineConstant("pos_QTL", c(pos.subsetColumns(3:(pos.ncol-1)).asMatrix()));
		
	// Optimum
	numTraits = 3;
	if (modelType == "NAR" | modelType == "PAR") { numTraits = 2; }
	if (modelType == "FFBH") { numTraits = 4; }

	// TODO: Remove inputPath - used for testing
	opt = readCSV(paste0(inputPath, "slim_opt", inputID, ".csv"), colNames = F);
	opt = (opt.subset(0, 2:(1+numTraits))).asMatrix();
	
	defineConstant("optimum", opt);
	
	// Misc initial values

	// Set delta difference value
	sim.setValue("lastDist", 0.0);
	sim.setValue("lastw", 0.0);
		
	// Set mutation rate
	// Calculate and set mutation rates according to n loci so we have a consistent per-genome rate
	u_g = genomelength * mu;
	u_q = u_g / nloci;
	u_n = u_g / (genomelength - nloci);
	
	// return early if we have no QTLs: mutation rate is always mu
	if (length(pos_QTL) == 0) {
		return;
	}
	
	// Set molMutCutoffs
	// mol traits are in order: first molMutProp[0]% are alpha, next molMutProp[1]% are beta, then KZ, then KXZ
	// figure out the actual cutoffs 
	molMuts = 7;

	// Set molMuts for different motifs
	if (modelType == "FFLC1" | modelType == "FFLI1") {
		molMuts = 9;
	}

	if (modelType == "FFBH") {
		molMuts = 11;
	}


	molMutres = getMolMutCutoffs(molMuts);

	defineConstant("molMutCutoffs", c(0, molMutres-1)); // convert to zero-indexed
	
	ends = unique(findMutBreakpoints(pos_QTL));
	

	// determine what rates to use: starting with neutral or qtl depending on whether we have a QTL at pos 0
	if (sort(pos_QTL)[0] == 0) {
		rates = rep(c(u_q, u_n), length(ends));
	} else {
		rates = rep(c(u_n, u_q), length(ends));
	}
	
	// shorten to match ends length
	rates = rates[0:(length(ends)-1)];	
		
	// get a vector of values
	sim.chromosome.setMutationRate(rates, ends);	
	
	// Optimum settings
	startTraits = getStartTraitValues(modelType);
	defineGlobal("optSigma", CalcSelectionSigmas(startTraits, 0.1)); // Calculate width of fitness function per axis

	
	// Calculate p2 phenotypes first so we don't overwrite p1 sim.setvalue("fitness")
	calcPhenotype(p2.individuals, modelType);
	calcPhenotype(p1.individuals, modelType);
	catn(opt);
	calcFitnessGaussian(p1.individuals, opt, modelType);
	
	setSeed(inputSeed);
	return;
}
